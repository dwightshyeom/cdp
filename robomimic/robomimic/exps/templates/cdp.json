{
  "algo_name": "cdp",
  "experiment": {
    "name": "cdp_box_push",
    "validate": false,
    "logging": {
      "terminal_output_to_txt": true,
      "log_tb": true,
      "log_wandb": true,
      "wandb_proj_name": "cdp"
    },
    "save": {
      "enabled": true,
      "every_n_seconds": null,
      "every_n_epochs": 50,
      "epochs": [],
      "on_best_validation": false,
      "on_best_rollout_return": false,
      "on_best_rollout_success_rate": true
    },
    "epoch_every_n_steps": 100,
    "validation_epoch_every_n_steps": 10,
    "env": null,
    "additional_envs": null,
    "render": false,
    "render_video": true,
    "keep_all_videos": false,
    "video_skip": 5,
    "rollout": {
      "enabled": false,
      "n": 20,
      "horizon": 400,
      "rate": 10,
      "warmstart": 0,
      "terminate_on_success": true
    },
    "ckpt_path": null
  },
  "train": {
    "data": "../robosuite/custom_dataset/low_dim_boxpush_120.hdf5",
    "output_dir": "../cdp_trained_models/",
    "num_data_workers": 0,
    "num_epochs": 2000,
    "hdf5_cache_mode": "all",
    "hdf5_use_swmr": true,
    "hdf5_load_next_obs": false,
    "hdf5_normalize_obs": false,
    "seq_length": 5,
    "pad_seq_length": true,
    "frame_stack": 1,
    "pad_frame_stack": true,
    "dataset_keys": [
      "actions",
      "rewards",
      "dones"
    ]
  },
  "algo": {
    "optim_params": {
      "policy": {
        "learning_rate": {
          "initial": 1e-4,
          "decay_factor": 0.99,
          "epoch_schedule": [100],
          "kwargs": {
            "weight_decay": 0.0
          }
        },
        "regularization": {
          "L2": 0.0
        },
        "optimizer_type": "adam"
      }
    },
    "horizon": {
      "observation_horizon": 5,
      "action_horizon": 1,
      "prediction_horizon": 5
    },
    "cfg": {
      "enabled": true,
      "uncond_prob": 0.1,
      "cond_lambda": 2.0,
      "goal_obs_keys": ["push_distance"]
    },
    "model": {
      "type": "diffusion_gpt",
      "embed_dim": 240,
      "num_hidden_layers": 4,
      "n_heads": 12,
      "attn_pdrop": 0.05,
      "resid_pdrop": 0.05,
      "linear_output": true,
      "embed_type": "Linear",
      "time_embed_dim": 240
    },
    "ema": {
      "enabled": true,
      "update_after_step": 1,
      "inv_gamma": 1.0,
      "power": 0.999,
      "min_value": 0.0,
      "max_value": 0.9999
    },
    "sampler": {
      "num_inference_steps": 3,
      "sampler_type": "ddim",
      "sigma_data": 0.5,
      "rho": 5.0,
      "sigma_min": 0.05,
      "sigma_max": 1.0,
      "sigma_sample_density_type": "loglogistic",
      "sigma_sample_density_mean": -0.6,
      "sigma_sample_density_std": 1.6,
      "noise_scheduler": "exponential"
    }
  },
  "observation": {
    "modalities": {
      "obs": {
        "low_dim": [
          "robot0_eef_pos",
          "robot0_eef_quat",
          "robot0_gripper_qpos",
          "object",
          "push_distance"
        ],
        "rgb": [],
        "depth": [],
        "scan": []
      },
      "goal": {
        "low_dim": [],
        "rgb": [],
        "depth": [],
        "scan": []
      }
    },
    "encoder": {
      "low_dim": {
        "core_class": null,
        "core_kwargs": {},
        "obs_randomizer_class": null,
        "obs_randomizer_kwargs": {}
      }
    }
  },
  "meta": {
    "hp_base_config_file": null,
    "hp_keys": [],
    "hp_values": []
  }
}